# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the FastAPI backend (no trailing slash)
# Local development: http://127.0.0.1:8000
# Production: https://your-backend-domain.com
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
